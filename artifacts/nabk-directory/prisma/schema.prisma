// Prisma schema for دليل النبك — pinned to Prisma 6.x

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS — existing
// ─────────────────────────────────────────────────────────────────────────────

enum Role {
  GUEST
  BUSINESS_OWNER
  ADMIN
  SUPER_ADMIN
}

enum BusinessStatus {
  DRAFT
  PENDING
  ACTIVE
  SUSPENDED
  REJECTED
}

enum MediaType {
  IMAGE
  VIDEO
}

enum MediaStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SuggestionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PhoneLabel {
  MOBILE
  LANDLINE
  WHATSAPP
  FAX
}

enum SocialPlatform {
  FACEBOOK
  INSTAGRAM
  TWITTER
  TIKTOK
  WHATSAPP
  TELEGRAM
  WEBSITE
}

enum CommentStatus {
  VISIBLE
  PENDING_REVIEW
  HIDDEN_BY_ADMIN
  DELETED_BY_USER
}

enum ContactMessageStatus {
  NEW
  READ
  RESOLVED
  SPAM
}

enum AuditAction {
  USER_CREATED
  USER_ROLE_CHANGED
  USER_EMAIL_VERIFIED_BY_ADMIN
  USER_VERIFICATION_RESENT
  USER_DELETED
  CONTACT_MESSAGE_RECEIVED
  CONTACT_MESSAGE_UPDATED
  CONTACT_MESSAGE_REPLIED
  COUNTRY_CREATED
  COUNTRY_UPDATED
  COUNTRY_DELETED
  CITY_CREATED
  CITY_UPDATED
  CITY_DELETED
  LISTING_CREATED
  LISTING_UPDATED
  LISTING_SUBMITTED
  LISTING_APPROVED
  LISTING_REJECTED
  LISTING_SUSPENDED
  LISTING_RESTORED
  LISTING_DELETED
  MEDIA_UPLOADED
  MEDIA_APPROVED
  MEDIA_REJECTED
  CATEGORY_CREATED
  CATEGORY_UPDATED
  CATEGORY_DELETED
  SUGGESTION_APPROVED
  SUGGESTION_REJECTED
  COMMENT_HIDDEN
  COMMENT_RESTORED
  COMMENT_APPROVED
  COMMENT_POSTED
  COMMENT_REMOVED_BY_USER
  RATING_SUBMITTED
  RATING_REMOVED_BY_USER
  RATING_DELETED
  // ── PDF system ──
  PDF_LEGACY_UPDATED
  PDF_LEGACY_PUBLISHED
  PDF_LEGACY_UNPUBLISHED
  PDF_EDITION_CREATED
  PDF_EDITION_UPDATED
  PDF_EDITION_PUBLISHED
  PDF_EDITION_ARCHIVED
  PDF_EDITION_DUPLICATED
  PDF_GENERATION_STARTED
  PDF_GENERATION_SUCCEEDED
  PDF_GENERATION_FAILED
  PDF_AD_CREATED
  PDF_AD_UPDATED
  PDF_AD_ACTIVATED
  PDF_AD_DEACTIVATED
  PDF_AD_DELETED
  PDF_WEBSITE_PROFILE_UPDATED
  PDF_DEVELOPER_PROFILE_UPDATED
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS — PDF system (new)
// ─────────────────────────────────────────────────────────────────────────────

/// How the legacy PDF is served to the public user
enum PdfLegacyOpenMode {
  PREVIEW           // open in embedded preview first
  DIRECT_DOWNLOAD   // trigger browser download immediately
  OPEN_IN_NEW_TAB   // open URL/file in a new browser tab
}

/// Where the legacy PDF file comes from
enum PdfLegacySourceType {
  FILE          // uploaded to our storage
  EXTERNAL_URL  // public URL managed externally
}

/// Lifecycle states of a PDF edition
enum PdfEditionStatus {
  DRAFT      // being edited, not visible to anyone outside admin
  REVIEW     // submitted for final review before publish
  PUBLISHED  // live — only one edition can be PUBLISHED at a time per city
  ARCHIVED   // replaced by a newer edition; kept for history
}

/// Supported ad placement slots inside the PDF
enum PdfAdPlacementType {
  FULL_PAGE
  HALF_PAGE_TOP
  HALF_PAGE_BOTTOM
  SIDEBAR_LEFT
  SIDEBAR_RIGHT
  HEADER_BANNER
  FOOTER_BANNER
  CATEGORY_SPONSOR
}

/// Which listing page template to use for a given category section
enum PdfListingTemplate {
  STANDARD         // single-column, generous spacing
  DENSE            // two-column, compact
  AD_HEAVY         // single-column with side-margin ad slot
  MIXED            // alternating blocks (featured + standard rows)
}

/// How businesses are ordered within a category section
enum PdfSortMode {
  ALPHABETICAL       // nameAr A → Z
  FEATURED_FIRST     // featured flag first, then alphabetical
  NEWEST_FIRST       // publishedAt desc
  CUSTOM             // admin-defined displayOrder on each listing (future)
}

/// Async generation job status
enum PdfJobStatus {
  QUEUED
  PROCESSING
  SUCCEEDED
  FAILED
}

// ─────────────────────────────────────────────────────────────────────────────
// EXISTING MODELS (unchanged)
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id                String    @id @default(cuid())
  name              String
  email             String    @unique
  passwordHash      String?
  role              Role      @default(BUSINESS_OWNER)
  emailVerified     DateTime?
  image             String?
  // Bumped whenever the password is reset; the JWT callback compares this
  // against the token's issued-at to invalidate older sessions.
  passwordChangedAt DateTime?
  deletedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  sessions                Session[]
  accounts                Account[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  loginTokens             LoginToken[]
  businessProfiles        BusinessProfile[]
  notifications           Notification[]
  auditLogs               AuditLog[]
  categorySuggestions     CategorySuggestion[]
  ratings                 Rating[]
  comments                Comment[]
  contactMessages         ContactMessage[]         @relation("ContactSender")
  repliedContactMessages  ContactMessage[]         @relation("ContactReplier")

  @@map("users")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("oauth_accounts")
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model LoginToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("login_tokens")
}

model Country {
  id        String   @id @default(cuid())
  nameAr    String
  nameEn    String
  slug      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cities    City[]

  @@map("countries")
}

model City {
  id        String            @id @default(cuid())
  countryId String?
  nameAr    String
  nameEn    String
  slug      String            @unique
  isActive  Boolean           @default(true)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @default(now()) @updatedAt
  country   Country?          @relation(fields: [countryId], references: [id])
  listings  BusinessProfile[]
  pdfEditions PdfEdition[]

  @@index([countryId])
  @@map("cities")
}

model Category {
  id           String            @id @default(cuid())
  nameAr       String
  nameEn       String
  slug         String            @unique
  icon         String?
  description  String?
  displayOrder Int               @default(0)
  isActive     Boolean           @default(true)
  parentId     String?
  parent       Category?         @relation("SubCategories", fields: [parentId], references: [id])
  children     Category[]        @relation("SubCategories")
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  listings     BusinessProfile[]
  subListings  BusinessProfile[] @relation("Subcategory")
  pdfEditionCategories PdfEditionCategory[]
  pdfAds       PdfAd[]

  @@map("categories")
}

model CategorySuggestion {
  id            String           @id @default(cuid())
  suggestedById String
  nameAr        String
  nameEn        String?
  reason        String?
  status        SuggestionStatus @default(PENDING)
  adminNote     String?
  reviewedById  String?
  reviewedAt    DateTime?
  createdAt     DateTime         @default(now())
  suggestedBy   User             @relation(fields: [suggestedById], references: [id])

  @@map("category_suggestions")
}

model BusinessProfile {
  id                        String         @id @default(cuid())
  ownerId                   String
  cityId                    String
  categoryId                String
  subcategoryId             String?
  nameAr                    String
  nameEn                    String?
  slug                      String         @unique
  descriptionAr             String?        @db.Text
  descriptionEn             String?        @db.Text
  addressAr                 String?
  latitude                  Float?
  longitude                 Float?
  status                    BusinessStatus @default(DRAFT)
  coverImageId              String?
  logoImageId               String?
  viewCount                 Int            @default(0)
  // Highest view-count milestone for which the owner has already received an
  // engagement notification — prevents duplicate "you reached X views"
  // pings if the page is refreshed after a milestone.
  lastNotifiedViewMilestone Int            @default(0)
  searchableText            String?        @db.Text
  ratingAverage             Float          @default(0)
  ratingCount               Int            @default(0)
  publishedAt               DateTime?
  suspendedAt               DateTime?
  suspensionReason          String?
  deletedAt                 DateTime?
  createdAt                 DateTime       @default(now())
  updatedAt                 DateTime       @updatedAt

  owner        User           @relation(fields: [ownerId], references: [id])
  city         City           @relation(fields: [cityId], references: [id])
  category     Category       @relation(fields: [categoryId], references: [id])
  subcategory  Category?      @relation("Subcategory", fields: [subcategoryId], references: [id])
  phoneNumbers PhoneNumber[]
  workingHours WorkingHours[]
  socialLinks  SocialLink[]
  mediaFiles   MediaFile[]
  ratings      Rating[]
  comments     Comment[]

  @@index([status, publishedAt])
  @@index([categoryId, status])
  @@map("business_profiles")
}

model Rating {
  id                String          @id @default(cuid())
  businessProfileId String
  userId            String
  score             Int
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  business          BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([businessProfileId, userId])
  @@index([businessProfileId])
  @@map("ratings")
}

model Comment {
  id                String          @id @default(cuid())
  businessProfileId String
  userId            String
  content           String          @db.Text
  status            CommentStatus   @default(VISIBLE)
  hiddenReason      String?
  parentId          String?
  parent            Comment?        @relation("Replies", fields: [parentId], references: [id])
  replies           Comment[]       @relation("Replies")
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  deletedAt         DateTime?
  business          BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([businessProfileId, createdAt(sort: Desc)])
  @@map("comments")
}

model PhoneNumber {
  id                String          @id @default(cuid())
  businessProfileId String
  label             PhoneLabel      @default(MOBILE)
  number            String
  displayOrder      Int             @default(0)
  business          BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)

  @@map("phone_numbers")
}

model WorkingHours {
  id                String          @id @default(cuid())
  businessProfileId String
  dayOfWeek         Int
  isOpen            Boolean         @default(true)
  openTime          String?
  closeTime         String?
  is24Hours         Boolean         @default(false)
  business          BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)

  @@unique([businessProfileId, dayOfWeek])
  @@map("working_hours")
}

model SocialLink {
  id                String          @id @default(cuid())
  businessProfileId String
  platform          SocialPlatform
  url               String
  business          BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)

  @@map("social_links")
}

model MediaFile {
  id                String          @id @default(cuid())
  businessProfileId String
  uploadedById      String
  type              MediaType
  storageKey        String
  url               String
  thumbnailUrl      String?
  fileSize          Int?
  mimeType          String?
  width             Int?
  height            Int?
  duration          Int?
  status            MediaStatus     @default(APPROVED)
  rejectionReason   String?
  displayOrder      Int             @default(0)
  createdAt         DateTime        @default(now())
  business          BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)

  @@map("media_files")
}

model Notification {
  id                String   @id @default(cuid())
  userId            String
  type              String
  titleAr           String
  messageAr         String
  isRead            Boolean  @default(false)
  relatedEntityType String?
  relatedEntityId   String?
  createdAt         DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model AuditLog {
  id             String      @id @default(cuid())
  actorId        String?
  actorEmail     String?
  actorRole      Role?
  action         AuditAction
  entityType     String
  entityId       String
  previousValues Json?
  newValues      Json?
  ipAddress      String?
  createdAt      DateTime    @default(now())
  actor          User?       @relation(fields: [actorId], references: [id])

  @@map("audit_logs")
}

model PlatformSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String   @db.Text
  description String?
  updatedAt   DateTime @updatedAt

  @@map("platform_settings")
}

// Public "contact us / help" inbox. Anyone (including unauthenticated
// guests) can submit a message; admins read and resolve them. We keep
// hashed IP and a short user-agent string for abuse triage but never
// expose them publicly.
model ContactMessage {
  id          String               @id @default(cuid())
  name        String
  email       String
  subject     String?
  message     String               @db.Text
  status      ContactMessageStatus @default(NEW)
  ipHash      String?
  userAgent   String?
  userId      String?
  user        User?                @relation("ContactSender", fields: [userId], references: [id], onDelete: SetNull)
  reply       String?              @db.Text
  repliedAt   DateTime?
  repliedById String?
  repliedBy   User?                @relation("ContactReplier", fields: [repliedById], references: [id], onDelete: SetNull)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([status, createdAt])
  @@index([userId])
  @@map("contact_messages")
}

// ─────────────────────────────────────────────────────────────────────────────
// PDF SYSTEM — NEW MODELS
// ─────────────────────────────────────────────────────────────────────────────

/// Admin-managed legacy printed directory.
/// Only ONE record should be isPublished=true at any time.
/// The hero "الدليل القديم" button reads this table.
model PdfLegacyFile {
  id             String               @id @default(cuid())
  titleAr        String
  titleEn        String?
  descriptionAr  String?              @db.Text
  descriptionEn  String?              @db.Text
  sourceType     PdfLegacySourceType
  /// Populated when sourceType = FILE (Cloudinary/storage URL)
  fileUrl        String?
  /// Populated when sourceType = EXTERNAL_URL
  externalUrl    String?
  coverImageUrl  String?
  buttonLabelAr  String               @default("الدليل القديم")
  buttonLabelEn  String?              @default("Old Directory")
  openMode       PdfLegacyOpenMode    @default(OPEN_IN_NEW_TAB)
  isPublished    Boolean              @default(false)
  publishedAt    DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@map("pdf_legacy_files")
}

/// One versioned edition of the dynamic PDF directory.
/// Status flow: DRAFT → REVIEW → PUBLISHED (one per city) → ARCHIVED
model PdfEdition {
  id                        String           @id @default(cuid())
  cityId                    String
  titleAr                   String
  titleEn                   String?
  /// URL-safe identifier, e.g. "nabk-2025-v2"
  slug                      String           @unique
  editionNumber             Int              @default(1)
  status                    PdfEditionStatus @default(DRAFT)

  // ── Cover & intro copy ──────────────────────────────────────────────────
  coverTitleAr              String?
  coverSubtitleAr           String?
  introTextAr               String?          @db.Text
  editorialTextAr           String?          @db.Text
  closingTextAr             String?          @db.Text

  // ── Feature toggles ──────────────────────────────────────────────────────
  includeAlphabeticalIndex  Boolean          @default(true)
  includeBusinessLogos      Boolean          @default(false)
  includeQrCodes            Boolean          @default(true)
  includeFeaturedBusinesses Boolean          @default(true)
  includeWebsiteProfile     Boolean          @default(true)
  includeDeveloperProfile   Boolean          @default(false)
  showEditionMetadata       Boolean          @default(true)

  // ── Generation settings ──────────────────────────────────────────────────
  /// FULL_CITY = all active businesses; SELECTED_CATEGORIES = only those in PdfEditionCategory
  generationMode            String           @default("FULL_CITY")
  /// A4 | LETTER
  pageSize                  String           @default("A4")

  // ── JSON blobs for flexible config (avoids dozens of nullable columns) ───
  /// { marginTop, marginBottom, marginLeft, marginRight } in mm
  marginsJson               Json?
  /// { primaryColor, accentColor, headingFont, bodyFont, … }
  themeJson                 Json?
  /// { showPageNumbers, pageNumberStyle, watermarkText, … }
  layoutJson                Json?

  // ── Output tracking ──────────────────────────────────────────────────────
  publishedAt               DateTime?
  createdAt                 DateTime         @default(now())
  updatedAt                 DateTime         @updatedAt

  city            City                 @relation(fields: [cityId], references: [id])
  categories      PdfEditionCategory[]
  editionAds      PdfEditionAd[]
  generationJobs  PdfGenerationJob[]

  @@index([cityId, status])
  @@index([status, publishedAt])
  @@map("pdf_editions")
}

/// Per-edition configuration for one category section.
/// Controls visual style, sort order, and layout template for that section.
model PdfEditionCategory {
  id              String             @id @default(cuid())
  pdfEditionId    String
  categoryId      String
  /// 1-based display order within this edition
  displayOrder    Int                @default(0)
  startOnNewPage  Boolean            @default(true)
  includeDivider  Boolean            @default(true)
  /// Hex colour override, e.g. "#1a6b3a" — falls back to edition theme
  colorTheme      String?
  sectionTitleAr  String?
  sectionIntroAr  String?            @db.Text
  listingTemplate PdfListingTemplate @default(STANDARD)
  sortMode        PdfSortMode        @default(ALPHABETICAL)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  edition  PdfEdition @relation(fields: [pdfEditionId], references: [id], onDelete: Cascade)
  category Category   @relation(fields: [categoryId], references: [id])

  @@unique([pdfEditionId, categoryId])
  @@index([pdfEditionId, displayOrder])
  @@map("pdf_edition_categories")
}

/// A single ad creative managed via the admin CMS.
/// Can be targeted to a specific category or left global.
model PdfAd {
  id             String             @id @default(cuid())
  titleAr        String
  advertiserName String
  imageUrl       String
  /// Optional click-through URL printed as QR or short URL
  targetUrl      String?
  phone          String?
  /// null = global ad; set = appears only near that category
  categoryId     String?
  placementType  PdfAdPlacementType
  /// Higher number = placed first when multiple ads compete for the same slot
  priority       Int                @default(0)
  startsAt       DateTime?
  endsAt         DateTime?
  isActive       Boolean            @default(true)
  notes          String?            @db.Text
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  category    Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  editionAds  PdfEditionAd[]

  @@index([isActive, placementType])
  @@index([categoryId, isActive])
  @@map("pdf_ads")
}

/// Join table linking a PdfAd to a specific PdfEdition.
/// Allows placement override per edition without mutating the ad record.
model PdfEditionAd {
  id                String              @id @default(cuid())
  pdfEditionId      String
  pdfAdId           String
  displayOrder      Int                 @default(0)
  /// Override the ad's default placement for this edition only
  overridePlacement PdfAdPlacementType?

  edition PdfEdition @relation(fields: [pdfEditionId], references: [id], onDelete: Cascade)
  ad      PdfAd      @relation(fields: [pdfAdId], references: [id], onDelete: Cascade)

  @@unique([pdfEditionId, pdfAdId])
  @@map("pdf_edition_ads")
}

/// Tracks every async PDF generation attempt for an edition.
/// One edition can have many jobs (re-generates after edits).
/// The LATEST SUCCEEDED job provides the canonical outputFileUrl.
model PdfGenerationJob {
  id                   String       @id @default(cuid())
  pdfEditionId         String
  status               PdfJobStatus @default(QUEUED)
  isPreview            Boolean      @default(false)
  /// Public URL of the final PDF (Cloudinary / R2 / etc.)
  outputFileUrl        String?
  /// Smaller preview-quality PDF URL with "مسودة" watermark
  previewFileUrl       String?
  outputFileSizeBytes  Int?
  previewFileSizeBytes Int?
  pagesCount           Int?
  businessesCount      Int?
  categoriesCount      Int?
  adsCount             Int?
  errorMessage         String?      @db.Text
  generatedAt          DateTime?
  createdAt            DateTime     @default(now())

  edition PdfEdition @relation(fields: [pdfEditionId], references: [id], onDelete: Cascade)

  @@index([pdfEditionId, status])
  @@index([pdfEditionId, createdAt(sort: Desc)])
  @@map("pdf_generation_jobs")
}

/// Dynamic website/platform profile block embedded in every edition.
/// Editable by ADMIN. Only ONE record should be isActive=true.
model WebsiteProfileBlock {
  id              String   @id @default(cuid())
  titleAr         String
  titleEn         String?
  shortTextAr     String?
  shortTextEn     String?
  bodyTextAr      String?  @db.Text
  bodyTextEn      String?  @db.Text
  websiteUrl      String?
  /// Pre-generated QR code image URL (can be regenerated on save)
  qrCodeUrl       String?
  supportEmail    String?
  supportPhone    String?
  /// JSON array: [{ platform, url }]
  socialLinksJson Json?
  logoUrl         String?
  bannerImageUrl  String?
  ctaTextAr       String?
  ctaTextEn       String?
  isActive        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("website_profile_blocks")
}

/// Dynamic developer/creator credits block.
/// Editable by SUPER_ADMIN only. isVisible controls whether it appears in generated PDFs.
model DeveloperProfileBlock {
  id              String   @id @default(cuid())
  fullName        String
  roleTitleAr     String?
  roleTitleEn     String?
  shortBioAr      String?
  shortBioEn      String?
  longBioAr       String?  @db.Text
  longBioEn       String?  @db.Text
  brandName       String?
  portfolioUrl    String?
  githubUrl       String?
  linkedinUrl     String?
  email           String?
  phone           String?
  whatsapp        String?
  /// JSON array: [{ platform, url }]
  socialLinksJson Json?
  profileImageUrl String?
  logoUrl         String?
  /// e.g. "تم التطوير بواسطة" / "Built by"
  ctaTextAr       String?
  ctaTextEn       String?
  isVisible       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("developer_profile_blocks")
}
