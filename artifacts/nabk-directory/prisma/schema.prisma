generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                                              String                   @id @default(cuid())
  name                                            String
  email                                           String                   @unique
  passwordHash                                    String?
  role                                            Role                     @default(BUSINESS_OWNER)
  emailVerified                                   DateTime?
  image                                           String?
  passwordChangedAt                               DateTime?
  deletedAt                                       DateTime?
  createdAt                                       DateTime                 @default(now())
  updatedAt                                       DateTime                 @updatedAt
  auditLogs                                       AuditLog[]
  businessProfiles                                BusinessProfile[]
  categorySuggestions                             CategorySuggestion[]
  comments                                        Comment[]
  repliedContactMessages                          ContactMessage[]         @relation("ContactReplier")
  contact_messages_contact_messages_userIdTousers ContactMessage[]         @relation("contact_messages_userIdTousers")
  emailVerificationTokens                         EmailVerificationToken[]
  loginTokens                                     LoginToken[]
  notifications                                   Notification[]
  accounts                                        Account[]
  passwordResetTokens                             PasswordResetToken[]
  ratings                                         Rating[]
  sessions                                        Session[]

  @@map("users")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("oauth_accounts")
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model LoginToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("login_tokens")
}

model Country {
  id        String   @id @default(cuid())
  nameAr    String
  nameEn    String
  slug      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cities    City[]

  @@map("countries")
}

model City {
  id          String            @id @default(cuid())
  nameAr      String
  nameEn      String
  slug        String            @unique
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  countryId   String?
  updatedAt   DateTime          @default(now()) @updatedAt
  listings    BusinessProfile[]
  country     Country?          @relation(fields: [countryId], references: [id])
  pdfEditions PdfEdition[]

  @@index([countryId])
  @@map("cities")
}

model Category {
  id                                                     String               @id @default(cuid())
  nameAr                                                 String
  nameEn                                                 String
  slug                                                   String               @unique
  icon                                                   String?
  description                                            String?
  displayOrder                                           Int                  @default(0)
  isActive                                               Boolean              @default(true)
  parentId                                               String?
  createdAt                                              DateTime             @default(now())
  updatedAt                                              DateTime             @updatedAt
  listings                                               BusinessProfile[]
  subListings                                            BusinessProfile[]    @relation("Subcategory")
  parent                                                 Category?            @relation("SubCategories", fields: [parentId], references: [id])
  children                                               Category[]           @relation("SubCategories")
  pdf_ads_pdf_ads_position_after_category_idTocategories PdfAd[]              @relation("pdf_ads_position_after_category_idTocategories")
  pdfEditionCategories                                   PdfEditionCategory[]

  @@map("categories")
}

model CategorySuggestion {
  id            String           @id @default(cuid())
  suggestedById String
  nameAr        String
  nameEn        String?
  reason        String?
  status        SuggestionStatus @default(PENDING)
  adminNote     String?
  reviewedById  String?
  reviewedAt    DateTime?
  createdAt     DateTime         @default(now())
  suggestedBy   User             @relation(fields: [suggestedById], references: [id])

  @@map("category_suggestions")
}

model BusinessProfile {
  id                        String               @id @default(cuid())
  ownerId                   String
  cityId                    String
  categoryId                String
  subcategoryId             String?
  nameAr                    String
  nameEn                    String?
  slug                      String               @unique
  descriptionAr             String?
  descriptionEn             String?
  addressAr                 String?
  latitude                  Float?
  longitude                 Float?
  status                    BusinessStatus       @default(DRAFT)
  coverImageId              String?
  logoImageId               String?
  viewCount                 Int                  @default(0)
  searchableText            String?
  ratingAverage             Float                @default(0)
  ratingCount               Int                  @default(0)
  publishedAt               DateTime?
  suspendedAt               DateTime?
  suspensionReason          String?
  deletedAt                 DateTime?
  createdAt                 DateTime             @default(now())
  updatedAt                 DateTime             @updatedAt
  lastNotifiedViewMilestone Int                  @default(0)
  category                  Category             @relation(fields: [categoryId], references: [id])
  city                      City                 @relation(fields: [cityId], references: [id])
  owner                     User                 @relation(fields: [ownerId], references: [id])
  subcategory               Category?            @relation("Subcategory", fields: [subcategoryId], references: [id])
  comments                  Comment[]
  media_files               MediaFile[]
  phones                    BusinessPhone[]
  ratings                   Rating[]
  socialLinks               BusinessSocialLink[]
  workingHours              WorkingHours[]

  @@index([categoryId, status])
  @@index([status, publishedAt])
  @@map("business_profiles")
}

model BusinessPhone {
  id                String          @id @default(cuid())
  businessProfileId String
  label             PhoneLabel      @default(MOBILE)
  number            String
  displayOrder      Int             @default(0)
  profile           BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)

  @@map("phone_numbers")
}

model BusinessSocialLink {
  id                String          @id @default(cuid())
  businessProfileId String
  platform          SocialPlatform
  url               String
  profile           BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)

  @@map("social_links")
}

model WorkingHours {
  id                String          @id @default(cuid())
  businessProfileId String
  dayOfWeek         Int
  isOpen            Boolean         @default(true)
  openTime          String?
  closeTime         String?
  is24Hours         Boolean         @default(false)
  profile           BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)

  @@unique([businessProfileId, dayOfWeek])
  @@map("working_hours")
}

model Rating {
  id                String          @id @default(cuid())
  businessProfileId String
  userId            String
  score             Int
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  business_profiles BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([businessProfileId, userId])
  @@map("ratings")
}

model Comment {
  id                String          @id @default(cuid())
  businessProfileId String
  userId            String
  parentId          String?
  content           String
  status            CommentStatus   @default(PENDING_REVIEW)
  adminNote         String?
  deletedAt         DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  business_profiles BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent            Comment?        @relation("CommentReplies", fields: [parentId], references: [id])
  replies           Comment[]       @relation("CommentReplies")

  @@map("comments")
}

model MediaFile {
  id                String          @id @default(cuid())
  businessProfileId String
  url               String
  type              MediaType       @default(IMAGE)
  caption           String?
  displayOrder      Int             @default(0)
  createdAt         DateTime        @default(now())
  business_profiles BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)

  @@map("media_files")
}

model ContactMessage {
  id          String               @id @default(cuid())
  userId      String?
  name        String
  email       String
  subject     String?
  message     String
  status      ContactMessageStatus @default(NEW)
  ipHash      String?
  userAgent   String?
  reply       String?
  repliedAt   DateTime?
  repliedById String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  repliedBy   User?                @relation("ContactReplier", fields: [repliedById], references: [id])
  user        User?                @relation("contact_messages_userIdTousers", fields: [userId], references: [id])

  @@map("contact_messages")
}

model Notification {
  id                String   @id @default(cuid())
  userId            String
  type              String
  titleAr           String
  messageAr         String
  isRead            Boolean  @default(false)
  relatedEntityType String?
  relatedEntityId   String?
  createdAt         DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

model AuditLog {
  id             String      @id @default(cuid())
  actorId        String?
  actorEmail     String?
  actorRole      Role?
  action         AuditAction
  entityType     String
  entityId       String
  previousValues Json?
  newValues      Json?
  ipAddress      String?
  createdAt      DateTime    @default(now())
  actor          User?       @relation(fields: [actorId], references: [id])

  @@index([entityType, entityId])
  @@map("audit_logs")
}

model LegacyPdfConfig {
  id            String              @id @default(cuid())
  titleAr       String
  titleEn       String?
  descriptionAr String?
  descriptionEn String?
  sourceType    PdfLegacySourceType
  fileUrl       String?
  externalUrl   String?
  coverImageUrl String?
  buttonLabelAr String              @default("الدليل القديم")
  buttonLabelEn String?
  openMode      PdfLegacyOpenMode   @default(PREVIEW)
  isPublished   Boolean             @default(false)
  publishedAt   DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@map("legacy_pdf_configs")
}

model PdfEdition {
  id                        String               @id @default(cuid())
  titleAr                   String
  slug                      String               @unique
  cityId                    String
  cityIdsJson               String               @default("[]")
  pageSize                  String               @default("A4")
  editionNumber             Int                  @default(1)
  generationMode            String               @default("ALL_ACTIVE")
  status                    PdfEditionStatus     @default(DRAFT)
  coverTitleAr              String?
  coverSubtitleAr           String?
  introTextAr               String?
  editorialTextAr           String?
  closingTextAr             String?
  includeQrCodes            Boolean              @default(true)
  includeBusinessLogos      Boolean              @default(true)
  includeAlphabeticalIndex  Boolean              @default(true)
  includeFeaturedBusinesses Boolean              @default(true)
  includeWebsiteProfile     Boolean              @default(true)
  includeDeveloperProfile   Boolean              @default(false)
  showEditionMetadata       Boolean              @default(true)
  publishedAt               DateTime?
  createdAt                 DateTime             @default(now())
  updatedAt                 DateTime             @updatedAt
  city                      City                 @relation(fields: [cityId], references: [id])
  generationJobs            PdfGenerationJob[]
  editionAds                PdfEditionAd[]
  editionCategories         PdfEditionCategory[]

  @@map("pdf_editions")
}

model PdfGenerationJob {
  id         String       @id @default(cuid())
  editionId  String
  status     PdfJobStatus @default(QUEUED)
  startedAt  DateTime?
  finishedAt DateTime?
  fileUrl    String?
  errorMsg   String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  edition    PdfEdition   @relation(fields: [editionId], references: [id], onDelete: Cascade)

  @@map("pdf_generation_jobs")
}

model PdfAd {
  id                      String             @id @default(cuid())
  titleAr                 String
  imageUrl                String
  linkUrl                 String?
  placementType           PdfAdPlacementType @default(FULL_PAGE)
  priority                Int                @default(0)
  isActive                Boolean            @default(true)
  positionAfterCategoryId String?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  position_after_category Category?          @relation("pdf_ads_position_after_category_idTocategories", fields: [positionAfterCategoryId], references: [id])
  editionAds              PdfEditionAd[]

  @@map("pdf_ads")
}

model PdfEditionAd {
  id           String     @id @default(cuid())
  editionId    String
  adId         String
  displayOrder Int        @default(0)
  edition      PdfEdition @relation(fields: [editionId], references: [id], onDelete: Cascade)
  ad           PdfAd      @relation(fields: [adId], references: [id], onDelete: Cascade)

  @@unique([editionId, adId])
  @@map("pdf_edition_ads")
}

model PdfEditionCategory {
  id           String             @id @default(cuid())
  editionId    String
  categoryId   String
  displayOrder Int                @default(0)
  template     PdfListingTemplate @default(STANDARD)
  sortMode     PdfSortMode        @default(ALPHABETICAL)
  edition      PdfEdition         @relation(fields: [editionId], references: [id], onDelete: Cascade)
  category     Category           @relation(fields: [categoryId], references: [id])

  @@unique([editionId, categoryId])
  @@map("pdf_edition_categories")
}

/// Singleton: one record holds the website info block shown in PDF editions.
/// Use upsert (findFirst + update/create) — never create more than one row.
model WebsiteProfileBlock {
  id           String   @id @default(cuid())
  titleAr      String
  shortTextAr  String?
  bodyTextAr   String?
  websiteUrl   String?
  supportEmail String?
  supportPhone String?
  ctaTextAr    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("website_profile_blocks")
}

/// Singleton: one record holds the developer bio block shown in PDF editions.
/// Use upsert (findFirst + update/create) — never create more than one row.
model DeveloperProfileBlock {
  id           String   @id @default(cuid())
  fullName     String
  roleTitleAr  String?
  shortBioAr   String?
  portfolioUrl String?
  email        String?
  phone        String?
  ctaTextAr    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("developer_profile_blocks")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  BUSINESS_OWNER
  USER
}

enum BusinessStatus {
  DRAFT
  PENDING
  ACTIVE
  SUSPENDED
  REJECTED
}

enum MediaType {
  IMAGE
  VIDEO
}

enum PhoneLabel {
  MOBILE
  LANDLINE
  WHATSAPP
  FAX
}

enum SocialPlatform {
  FACEBOOK
  INSTAGRAM
  TWITTER
  TIKTOK
  WHATSAPP
  TELEGRAM
  WEBSITE
}

enum ContactMessageStatus {
  NEW
  READ
  RESOLVED
  SPAM
}

enum CommentStatus {
  VISIBLE
  PENDING_REVIEW
  HIDDEN_BY_ADMIN
  DELETED_BY_USER
}

enum SuggestionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AuditAction {
  USER_CREATED
  USER_UPDATED
  USER_DELETED
  USER_SUSPENDED
  USER_ROLE_CHANGED
  USER_PASSWORD_CHANGED
  USER_EMAIL_CHANGED
  USER_LOGIN
  USER_LOGOUT
  USER_VERIFIED
  LISTING_CREATED
  LISTING_UPDATED
  LISTING_SUBMITTED
  LISTING_APPROVED
  LISTING_REJECTED
  LISTING_SUSPENDED
  LISTING_RESTORED
  LISTING_DELETED
  MEDIA_UPLOADED
  MEDIA_DELETED
  CATEGORY_CREATED
  CATEGORY_UPDATED
  CATEGORY_DELETED
  SUGGESTION_APPROVED
  SUGGESTION_REJECTED
  COMMENT_HIDDEN
  COMMENT_RESTORED
  RATING_DELETED
  COMMENT_APPROVED
  COMMENT_POSTED
  COMMENT_REMOVED_BY_USER
  RATING_SUBMITTED
  RATING_REMOVED_BY_USER
  USER_EMAIL_VERIFIED_BY_ADMIN
  USER_VERIFICATION_RESENT
  CONTACT_MESSAGE_RECEIVED
  CONTACT_MESSAGE_UPDATED
  CONTACT_MESSAGE_REPLIED
  COUNTRY_CREATED
  COUNTRY_UPDATED
  COUNTRY_DELETED
  CITY_CREATED
  CITY_UPDATED
  CITY_DELETED
  PDF_LEGACY_UPDATED
  PDF_LEGACY_PUBLISHED
  PDF_LEGACY_UNPUBLISHED
  PDF_EDITION_CREATED
  PDF_EDITION_UPDATED
  PDF_EDITION_PUBLISHED
  PDF_EDITION_ARCHIVED
  PDF_EDITION_DUPLICATED
  PDF_GENERATION_STARTED
  PDF_GENERATION_SUCCEEDED
  PDF_GENERATION_FAILED
  PDF_AD_CREATED
  PDF_AD_UPDATED
  PDF_AD_DELETED
  PDF_WEBSITE_PROFILE_UPDATED
  PDF_DEVELOPER_PROFILE_UPDATED
  PDF_AD_ACTIVATED
  PDF_AD_DEACTIVATED
}

/// How the legacy PDF is served to the public user
enum PdfLegacyOpenMode {
  PREVIEW
  DIRECT_DOWNLOAD
  OPEN_IN_NEW_TAB
}

/// Where the legacy PDF file comes from
enum PdfLegacySourceType {
  FILE
  EXTERNAL_URL
}

/// Lifecycle states of a PDF edition
enum PdfEditionStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
}

/// Supported ad placement slots inside the PDF
enum PdfAdPlacementType {
  FULL_PAGE
  HALF_PAGE_TOP
  HALF_PAGE_BOTTOM
  SIDEBAR_LEFT
  SIDEBAR_RIGHT
  HEADER_BANNER
  FOOTER_BANNER
  CATEGORY_SPONSOR
}

/// Which listing page template to use for a given category section
enum PdfListingTemplate {
  STANDARD
  DENSE
  AD_HEAVY
  MIXED
}

/// How businesses are ordered within a category section
enum PdfSortMode {
  ALPHABETICAL
  FEATURED_FIRST
  NEWEST_FIRST
  CUSTOM
}

/// Async generation job status
enum PdfJobStatus {
  QUEUED
  PROCESSING
  SUCCEEDED
  FAILED
}
