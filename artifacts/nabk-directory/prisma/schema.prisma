// Prisma schema for دليل النبك — pinned to Prisma 6.x

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS — existing
// ─────────────────────────────────────────────────────────────────────────────

enum Role {
  GUEST
  BUSINESS_OWNER
  ADMIN
  SUPER_ADMIN
}

enum BusinessStatus {
  DRAFT
  PENDING
  ACTIVE
  SUSPENDED
  REJECTED
}

enum MediaType {
  IMAGE
  VIDEO
}

enum MediaStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SuggestionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PhoneLabel {
  MOBILE
  LANDLINE
  WHATSAPP
  FAX
}

enum SocialPlatform {
  FACEBOOK
  INSTAGRAM
  TWITTER
  TIKTOK
  WHATSAPP
  TELEGRAM
  WEBSITE
}

enum CommentStatus {
  VISIBLE
  PENDING_REVIEW
  HIDDEN_BY_ADMIN
  DELETED_BY_USER
}

enum ContactMessageStatus {
  NEW
  READ
  RESOLVED
  SPAM
}

enum AuditAction {
  USER_CREATED
  USER_ROLE_CHANGED
  USER_EMAIL_VERIFIED_BY_ADMIN
  USER_VERIFICATION_RESENT
  USER_DELETED
  CONTACT_MESSAGE_RECEIVED
  CONTACT_MESSAGE_UPDATED
  CONTACT_MESSAGE_REPLIED
  COUNTRY_CREATED
  COUNTRY_UPDATED
  COUNTRY_DELETED
  CITY_CREATED
  CITY_UPDATED
  CITY_DELETED
  LISTING_CREATED
  LISTING_UPDATED
  LISTING_SUBMITTED
  LISTING_APPROVED
  LISTING_REJECTED
  LISTING_SUSPENDED
  LISTING_RESTORED
  LISTING_DELETED
  MEDIA_UPLOADED
  MEDIA_APPROVED
  MEDIA_REJECTED
  CATEGORY_CREATED
  CATEGORY_UPDATED
  CATEGORY_DELETED
  SUGGESTION_APPROVED
  SUGGESTION_REJECTED
  COMMENT_HIDDEN
  COMMENT_RESTORED
  COMMENT_APPROVED
  COMMENT_POSTED
  COMMENT_REMOVED_BY_USER
  RATING_SUBMITTED
  RATING_REMOVED_BY_USER
  RATING_DELETED
  // ── PDF system ──
  PDF_LEGACY_UPDATED
  PDF_LEGACY_PUBLISHED
  PDF_LEGACY_UNPUBLISHED
  PDF_EDITION_CREATED
  PDF_EDITION_UPDATED
  PDF_EDITION_PUBLISHED
  PDF_EDITION_ARCHIVED
  PDF_EDITION_DUPLICATED
  PDF_GENERATION_STARTED
  PDF_GENERATION_SUCCEEDED
  PDF_GENERATION_FAILED
  PDF_AD_CREATED
  PDF_AD_UPDATED
  PDF_AD_ACTIVATED
  PDF_AD_DEACTIVATED
  PDF_AD_DELETED
  PDF_WEBSITE_PROFILE_UPDATED
  PDF_DEVELOPER_PROFILE_UPDATED
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS — PDF system (new)
// ─────────────────────────────────────────────────────────────────────────────

/// How the legacy PDF is served to the public user
enum PdfLegacyOpenMode {
  PREVIEW           // open in embedded preview first
  DIRECT_DOWNLOAD   // trigger browser download immediately
  OPEN_IN_NEW_TAB   // open URL/file in a new browser tab
}

/// Where the legacy PDF file comes from
enum PdfLegacySourceType {
  FILE          // uploaded to our storage
  EXTERNAL_URL  // public URL managed externally
}

/// Lifecycle states of a PDF edition
enum PdfEditionStatus {
  DRAFT      // being edited, not visible to anyone outside admin
  REVIEW     // submitted for final review before publish
  PUBLISHED  // live — only one edition can be PUBLISHED at a time per city
  ARCHIVED   // replaced by a newer edition; kept for history
}

/// Supported ad placement slots inside the PDF
enum PdfAdPlacementType {
  FULL_PAGE
  HALF_PAGE_TOP
  HALF_PAGE_BOTTOM
  SIDEBAR_LEFT
  SIDEBAR_RIGHT
  HEADER_BANNER
  FOOTER_BANNER
  CATEGORY_SPONSOR
}

/// Which listing page template to use for a given category section
enum PdfListingTemplate {
  STANDARD         // single-column, generous spacing
  DENSE            // two-column, compact
  AD_HEAVY         // single-column with side-margin ad slot
  MIXED            // alternating blocks (featured + standard rows)
}

/// How businesses are ordered within a category section
enum PdfSortMode {
  ALPHABETICAL       // nameAr A → Z
  FEATURED_FIRST     // featured flag first, then alphabetical
  NEWEST_FIRST       // publishedAt desc
  CUSTOM             // admin-defined displayOrder on each listing (future)
}

/// Async generation job status
enum PdfJobStatus {
  QUEUED
  PROCESSING
  SUCCEEDED
  FAILED
}

// ─────────────────────────────────────────────────────────────────────────────
// EXISTING MODELS (unchanged)
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id                String    @id @default(cuid())
  name              String
  email             String    @unique
  passwordHash      String?
  role              Role      @default(BUSINESS_OWNER)
  emailVerified     DateTime?
  image             String?
  passwordChangedAt DateTime?
  deletedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  sessions                Session[]
  accounts                Account[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  loginTokens             LoginToken[]
  businessProfiles        BusinessProfile[]
  notifications           Notification[]
  auditLogs               AuditLog[]
  categorySuggestions     CategorySuggestion[]
  ratings                 Rating[]
  comments                Comment[]
  contactMessages         ContactMessage[]         @relation("ContactSender")
  repliedContactMessages  ContactMessage[]         @relation("ContactReplier")

  @@map("users")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id])

  @@unique([provider, providerAccountId])
  @@map("oauth_accounts")
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model LoginToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("login_tokens")
}

model Country {
  id        String   @id @default(cuid())
  nameAr    String
  nameEn    String
  slug      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cities    City[]

  @@map("countries")
}

model City {
  id        String            @id @default(cuid())
  countryId String?
  nameAr    String
  nameEn    String
  slug      String            @unique
  isActive  Boolean           @default(true)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @default(now()) @updatedAt
  country   Country?          @relation(fields: [countryId], references: [id])
  listings  BusinessProfile[]
  pdfEditions PdfEdition[]

  @@index([countryId])
  @@map("cities")
}

model Category {
  id           String            @id @default(cuid())
  nameAr       String
  nameEn       String
  slug         String            @unique
  icon         String?
  description  String?
  displayOrder Int               @default(0)
  isActive     Boolean           @default(true)
  parentId     String?
  parent       Category?         @relation("SubCategories", fields: [parentId], references: [id])
  children     Category[]        @relation("SubCategories")
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  listings     BusinessProfile[]
  subListings  BusinessProfile[] @relation("Subcategory")
  pdfEditionCategories PdfEditionCategory[]
  pdfAds       PdfAd[]

  @@map("categories")
}

model CategorySuggestion {
  id            String           @id @default(cuid())
  suggestedById String
  nameAr        String
  nameEn        String?
  reason        String?
  status        SuggestionStatus @default(PENDING)
  adminNote     String?
  reviewedById  String?
  reviewedAt    DateTime?
  createdAt     DateTime         @default(now())
  suggestedBy   User             @relation(fields: [suggestedById], references: [id])

  @@map("category_suggestions")
}

model BusinessProfile {
  id                        String         @id @default(cuid())
  ownerId                   String
  cityId                    String
  categoryId                String
  subcategoryId             String?
  nameAr                    String
  nameEn                    String?
  slug                      String         @unique
  descriptionAr             String?        @db.Text
  descriptionEn             String?        @db.Text
  addressAr                 String?
  latitude                  Float?
  longitude                 Float?
  status                    BusinessStatus @default(DRAFT)
  coverImageId              String?
  logoImageId               String?
  viewCount                 Int            @default(0)
  lastNotifiedViewMilestone Int            @default(0)
  searchableText            String?        @db.Text
  ratingAverage             Float          @default(0)
  ratingCount               Int            @default(0)
  publishedAt               DateTime?
  suspendedAt               DateTime?
  suspensionReason          String?
  deletedAt                 DateTime?
  createdAt                 DateTime       @default(now())
  updatedAt                 DateTime       @updatedAt

  owner        User           @relation(fields: [ownerId], references: [id])
  city         City           @relation(fields: [cityId], references: [id])
  category     Category       @relation(fields: [categoryId], references: [id])
  subcategory  Category?      @relation("Subcategory", fields: [subcategoryId], references: [id])
  phoneNumbers PhoneNumber[]
  workingHours WorkingHours[]
  socialLinks  SocialLink[]
  mediaFiles   MediaFile[]
  ratings      Rating[]
  comments     Comment[]

  @@index([status, publishedAt])
  @@index([categoryId, status])
  @@map("business_profiles")
}

model Rating {
  id                String          @id @default(cuid())
  businessProfileId String
  userId            String
  score             Int
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  business          BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([businessProfileId, userId])
  @@index([businessProfileId])
  @@map("ratings")
}

model Comment {
  id                String          @id @default(cuid())
  businessProfileId String
  userId            String
  content           String          @db.Text
  status            CommentStatus   @default(VISIBLE)
  hiddenReason      String?
  parentId          String?
  parent            Comment?        @relation("Replies", fields: [parentId], references: [id])
  replies           Comment[]       @relation("Replies")
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  deletedAt         DateTime?
  business          BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([businessProfileId, createdAt(sort: Desc)])
  @@map("comments")
}

model PhoneNumber {
  id                String          @id @default(cuid())
  businessProfileId String
  label             PhoneLabel      @default(MOBILE)
  number            String
  displayOrder      Int             @default(0)
  business          BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)

  @@map("phone_numbers")
}

model WorkingHours {
  id                String          @id @default(cuid())
  businessProfileId String
  dayOfWeek         Int
  isOpen            Boolean         @default(true)
  openTime          String?
  closeTime         String?
  business          BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)

  @@map("working_hours")
}

model SocialLink {
  id                String          @id @default(cuid())
  businessProfileId String
  platform          SocialPlatform
  url               String
  business          BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)

  @@map("social_links")
}

model MediaFile {
  id                String          @id @default(cuid())
  businessProfileId String
  type              MediaType
  status            MediaStatus     @default(PENDING)
  url               String
  publicId          String?
  caption           String?
  displayOrder      Int             @default(0)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  business          BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)

  @@map("media_files")
}

model AuditLog {
  id          String      @id @default(cuid())
  actorId     String
  actorEmail  String
  actorRole   Role
  action      AuditAction
  entityType  String
  entityId    String
  oldValues   Json?
  newValues   Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime    @default(now())
  actor       User        @relation(fields: [actorId], references: [id])

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([createdAt(sort: Desc)])
  @@map("audit_logs")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  titleAr   String
  bodyAr    String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

model ContactMessage {
  id          String               @id @default(cuid())
  senderId    String?
  name        String
  email       String
  subject     String
  body        String               @db.Text
  status      ContactMessageStatus @default(NEW)
  repliedById String?
  repliedAt   DateTime?
  replyBody   String?              @db.Text
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  sender      User?                @relation("ContactSender", fields: [senderId], references: [id])
  repliedBy   User?                @relation("ContactReplier", fields: [repliedById], references: [id])

  @@index([status, createdAt(sort: Desc)])
  @@map("contact_messages")
}

// ─────────────────────────────────────────────────────────────────────────────
// PDF SYSTEM MODELS
// ─────────────────────────────────────────────────────────────────────────────

/// Singleton legacy PDF config (one per city or global)
model LegacyPdfConfig {
  id           String               @id @default(cuid())
  cityId       String?              @unique
  sourceType   PdfLegacySourceType  @default(EXTERNAL_URL)
  fileUrl      String?              // Cloudinary / R2 URL when sourceType = FILE
  externalUrl  String?              // direct external link when sourceType = EXTERNAL_URL
  openMode     PdfLegacyOpenMode    @default(OPEN_IN_NEW_TAB)
  isPublished  Boolean              @default(false)
  publishedAt  DateTime?
  updatedAt    DateTime             @updatedAt
  createdAt    DateTime             @default(now())

  @@map("legacy_pdf_configs")
}

/// A generated directory edition
model PdfEdition {
  id                        String          @id @default(cuid())
  cityId                    String
  cityIdsJson               String          @default("[]")
  slug                      String          @unique
  titleAr                   String
  coverTitleAr              String?
  coverSubtitleAr           String?
  introTextAr               String?         @db.Text
  editorialTextAr           String?         @db.Text
  closingTextAr             String?         @db.Text
  editionNumber             Int             @default(1)
  status                    PdfEditionStatus @default(DRAFT)
  pageSize                  String          @default("A4")
  generationMode            String          @default("ALL_ACTIVE")
  themeJson                 String?         @db.Text
  marginsJson               String?         @db.Text
  layoutJson                String?         @db.Text
  includeAlphabeticalIndex  Boolean         @default(true)
  includeBusinessLogos      Boolean         @default(true)
  includeQrCodes            Boolean         @default(true)
  includeFeaturedBusinesses Boolean         @default(true)
  includeWebsiteProfile     Boolean         @default(false)
  includeDeveloperProfile   Boolean         @default(false)
  showEditionMetadata       Boolean         @default(true)
  generatedFileUrl          String?
  generatedAt               DateTime?
  publishedAt               DateTime?
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt

  city                City                 @relation(fields: [cityId], references: [id])
  categories          PdfEditionCategory[]
  ads                 PdfEditionAd[]
  generationJobs      PdfGenerationJob[]

  @@index([cityId, status])
  @@map("pdf_editions")
}

/// Junction: which categories are included in an edition, with per-section config
model PdfEditionCategory {
  id               String           @id @default(cuid())
  editionId        String
  categoryId       String
  displayOrder     Int              @default(0)
  startOnNewPage   Boolean          @default(true)
  sectionTitleAr   String?
  sectionIntroAr   String?          @db.Text
  colorTheme       String?
  listingTemplate  PdfListingTemplate @default(STANDARD)
  sortMode         PdfSortMode      @default(ALPHABETICAL)

  edition          PdfEdition       @relation(fields: [editionId], references: [id], onDelete: Cascade)
  category         Category         @relation(fields: [categoryId], references: [id])

  @@unique([editionId, categoryId])
  @@map("pdf_edition_categories")
}

/// Ad asset — a reusable creative
model PdfAd {
  id             String             @id @default(cuid())
  titleAr        String
  advertiserName String
  imageUrl       String
  targetUrl      String?
  phone          String?
  placementType  PdfAdPlacementType @default(FULL_PAGE)
  priority       Int                @default(0)
  isActive       Boolean            @default(true)

  /// Task-4: pin this ad to appear after a specific category section.
  /// When set, the generator places the ad immediately after that category's pages.
  /// When null, the ad is distributed automatically (round-robin).
  positionAfterCategoryId  String?   @map("position_after_category_id")
  positionAfterCategory    Category? @relation(fields: [positionAfterCategoryId], references: [id], onDelete: SetNull)

  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  editions       PdfEditionAd[]

  @@index([isActive, priority(sort: Desc)])
  @@index([positionAfterCategoryId])
  @@map("pdf_ads")
}

/// Junction: which ads appear in an edition, with optional placement override
model PdfEditionAd {
  id                String              @id @default(cuid())
  editionId         String
  adId              String
  overridePlacement PdfAdPlacementType?
  displayOrder      Int                 @default(0)

  edition           PdfEdition          @relation(fields: [editionId], references: [id], onDelete: Cascade)
  ad                PdfAd               @relation(fields: [adId], references: [id], onDelete: Cascade)

  @@unique([editionId, adId])
  @@map("pdf_edition_ads")
}

/// Async generation job log
model PdfGenerationJob {
  id            String        @id @default(cuid())
  editionId     String
  status        PdfJobStatus  @default(QUEUED)
  triggeredById String?
  startedAt     DateTime?
  finishedAt    DateTime?
  errorMessage  String?       @db.Text
  outputFileUrl String?
  pagesCount    Int?
  fileSizeBytes Int?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  edition       PdfEdition    @relation(fields: [editionId], references: [id], onDelete: Cascade)

  @@index([editionId, status])
  @@map("pdf_generation_jobs")
}

/// Website/directory profile block (shown at the end of the PDF)
model WebsiteProfileBlock {
  id           String   @id @default(cuid())
  titleAr      String
  shortTextAr  String?
  bodyTextAr   String?  @db.Text
  websiteUrl   String?
  supportEmail String?
  supportPhone String?
  ctaTextAr    String?
  logoUrl      String?
  qrCodeUrl    String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("website_profile_blocks")
}

/// Developer/maintainer profile block (shown at the very end)
model DeveloperProfileBlock {
  id               String   @id @default(cuid())
  fullName         String
  roleTitleAr      String?
  shortBioAr       String?  @db.Text
  portfolioUrl     String?
  email            String?
  phone            String?
  profileImageUrl  String?
  ctaTextAr        String?
  isVisible        Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("developer_profile_blocks")
}
