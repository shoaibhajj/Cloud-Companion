// Prisma schema for دليل النبك — pinned to Prisma 6.x

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS — existing
// ─────────────────────────────────────────────────────────────────────────────

enum Role {
  GUEST
  BUSINESS_OWNER
  ADMIN
  SUPER_ADMIN
}

enum BusinessStatus {
  DRAFT
  PENDING
  ACTIVE
  SUSPENDED
  REJECTED
}

enum MediaType {
  IMAGE
  VIDEO
}

enum MediaStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SuggestionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PhoneLabel {
  MOBILE
  LANDLINE
  WHATSAPP
  FAX
}

enum SocialPlatform {
  FACEBOOK
  INSTAGRAM
  TWITTER
  TIKTOK
  WHATSAPP
  TELEGRAM
  WEBSITE
}

enum CommentStatus {
  VISIBLE
  PENDING_REVIEW
  HIDDEN_BY_ADMIN
  DELETED_BY_USER
}

enum ContactMessageStatus {
  NEW
  READ
  RESOLVED
  SPAM
}

enum AuditAction {
  USER_CREATED
  USER_ROLE_CHANGED
  USER_EMAIL_VERIFIED_BY_ADMIN
  USER_VERIFICATION_RESENT
  USER_DELETED
  CONTACT_MESSAGE_RECEIVED
  CONTACT_MESSAGE_UPDATED
  CONTACT_MESSAGE_REPLIED
  COUNTRY_CREATED
  COUNTRY_UPDATED
  COUNTRY_DELETED
  CITY_CREATED
  CITY_UPDATED
  CITY_DELETED
  LISTING_CREATED
  LISTING_UPDATED
  LISTING_SUBMITTED
  LISTING_APPROVED
  LISTING_REJECTED
  LISTING_SUSPENDED
  LISTING_RESTORED
  LISTING_DELETED
  MEDIA_UPLOADED
  MEDIA_APPROVED
  MEDIA_REJECTED
  CATEGORY_CREATED
  CATEGORY_UPDATED
  CATEGORY_DELETED
  SUGGESTION_APPROVED
  SUGGESTION_REJECTED
  COMMENT_HIDDEN
  COMMENT_RESTORED
  COMMENT_APPROVED
  COMMENT_POSTED
  COMMENT_REMOVED_BY_USER
  RATING_SUBMITTED
  RATING_REMOVED_BY_USER
  RATING_DELETED
  // ── PDF system ──
  PDF_LEGACY_UPDATED
  PDF_LEGACY_PUBLISHED
  PDF_LEGACY_UNPUBLISHED
  PDF_EDITION_CREATED
  PDF_EDITION_UPDATED
  PDF_EDITION_PUBLISHED
  PDF_EDITION_ARCHIVED
  PDF_EDITION_DUPLICATED
  PDF_GENERATION_STARTED
  PDF_GENERATION_SUCCEEDED
  PDF_GENERATION_FAILED
  PDF_AD_CREATED
  PDF_AD_UPDATED
  PDF_AD_ACTIVATED
  PDF_AD_DEACTIVATED
  PDF_AD_DELETED
  PDF_WEBSITE_PROFILE_UPDATED
  PDF_DEVELOPER_PROFILE_UPDATED
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS — PDF system (new)
// ─────────────────────────────────────────────────────────────────────────────

/// How the legacy PDF is served to the public user
enum PdfLegacyOpenMode {
  PREVIEW           // open in embedded preview first
  DIRECT_DOWNLOAD   // trigger browser download immediately
  OPEN_IN_NEW_TAB   // open URL/file in a new browser tab
}

/// Where the legacy PDF file comes from
enum PdfLegacySourceType {
  FILE          // uploaded to our storage
  EXTERNAL_URL  // public URL managed externally
}

/// Lifecycle states of a PDF edition
enum PdfEditionStatus {
  DRAFT      // being edited, not visible to anyone outside admin
  REVIEW     // submitted for final review before publish
  PUBLISHED  // live — only one edition can be PUBLISHED at a time per city
  ARCHIVED   // replaced by a newer edition; kept for history
}

/// Supported ad placement slots inside the PDF
enum PdfAdPlacementType {
  FULL_PAGE
  HALF_PAGE_TOP
  HALF_PAGE_BOTTOM
  SIDEBAR_LEFT
  SIDEBAR_RIGHT
  HEADER_BANNER
  FOOTER_BANNER
  CATEGORY_SPONSOR
}

/// Which listing page template to use for a given category section
enum PdfListingTemplate {
  STANDARD         // single-column, generous spacing
  DENSE            // two-column, compact
  AD_HEAVY         // single-column with side-margin ad slot
  MIXED            // alternating blocks (featured + standard rows)
}

/// How businesses are ordered within a category section
enum PdfSortMode {
  ALPHABETICAL       // nameAr A → Z
  FEATURED_FIRST     // featured flag first, then alphabetical
  NEWEST_FIRST       // publishedAt desc
  CUSTOM             // admin-defined displayOrder on each listing (future)
}

/// Async generation job status
enum PdfJobStatus {
  QUEUED
  PROCESSING
  SUCCEEDED
  FAILED
}

// ─────────────────────────────────────────────────────────────────────────────
// EXISTING MODELS (unchanged)
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id                String    @id @default(cuid())
  name              String
  email             String    @unique
  passwordHash      String?
  role              Role      @default(BUSINESS_OWNER)
  emailVerified     DateTime?
  image             String?
  passwordChangedAt DateTime?
  deletedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  sessions                Session[]
  accounts                Account[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  loginTokens             LoginToken[]
  businessProfiles        BusinessProfile[]
  notifications           Notification[]
  auditLogs               AuditLog[]
  categorySuggestions     CategorySuggestion[]
  ratings                 Rating[]
  comments                Comment[]
  contactMessages         ContactMessage[]         @relation("ContactSender")
  repliedContactMessages  ContactMessage[]         @relation("ContactReplier")

  @@map("users")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id])

  @@unique([provider, providerAccountId])
  @@map("oauth_accounts")
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model LoginToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("login_tokens")
}

model Country {
  id        String   @id @default(cuid())
  nameAr    String
  nameEn    String
  slug      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cities    City[]

  @@map("countries")
}

model City {
  id        String            @id @default(cuid())
  countryId String?
  nameAr    String
  nameEn    String
  slug      String            @unique
  isActive  Boolean           @default(true)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @default(now()) @updatedAt
  country   Country?          @relation(fields: [countryId], references: [id])
  listings  BusinessProfile[]
  pdfEditions PdfEdition[]

  @@index([countryId])
  @@map("cities")
}

model Category {
  id           String            @id @default(cuid())
  nameAr       String
  nameEn       String
  slug         String            @unique
  icon         String?
  description  String?
  displayOrder Int               @default(0)
  isActive     Boolean           @default(true)
  parentId     String?
  parent       Category?         @relation("SubCategories", fields: [parentId], references: [id])
  children     Category[]        @relation("SubCategories")
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  listings     BusinessProfile[]
  subListings  BusinessProfile[] @relation("Subcategory")
  pdfEditionCategories PdfEditionCategory[]
  pdfAds       PdfAd[]

  @@map("categories")
}

model CategorySuggestion {
  id            String           @id @default(cuid())
  suggestedById String
  nameAr        String
  nameEn        String?
  reason        String?
  status        SuggestionStatus @default(PENDING)
  adminNote     String?
  reviewedById  String?
  reviewedAt    DateTime?
  createdAt     DateTime         @default(now())
  suggestedBy   User             @relation(fields: [suggestedById], references: [id])

  @@map("category_suggestions")
}

model BusinessProfile {
  id                        String         @id @default(cuid())
  ownerId                   String
  cityId                    String
  categoryId                String
  subcategoryId             String?
  nameAr                    String
  nameEn                    String?
  slug                      String         @unique
  descriptionAr             String?        @db.Text
  descriptionEn             String?        @db.Text
  addressAr                 String?
  latitude                  Float?
  longitude                 Float?
  status                    BusinessStatus @default(DRAFT)
  coverImageId              String?
  logoImageId               String?
  viewCount                 Int            @default(0)
  lastNotifiedViewMilestone Int            @default(0)
  searchableText            String?        @db.Text
  ratingAverage             Float          @default(0)
  ratingCount               Int            @default(0)
  publishedAt               DateTime?
  createdAt                 DateTime       @default(now())
  updatedAt                 DateTime       @updatedAt

  owner       User      @relation(fields: [ownerId], references: [id])
  city        City      @relation(fields: [cityId], references: [id])
  category    Category  @relation(fields: [categoryId], references: [id])
  subcategory Category? @relation("Subcategory", fields: [subcategoryId], references: [id])
  phones      BusinessPhone[]
  socialLinks BusinessSocialLink[]
  workingHours WorkingHours[]
  media       BusinessMedia[]
  tags        BusinessTag[]
  ratings     Rating[]
  comments    Comment[]

  @@index([cityId])
  @@index([categoryId])
  @@index([status])
  @@index([ownerId])
  @@map("business_profiles")
}

model BusinessPhone {
  id         String     @id @default(cuid())
  profileId  String
  number     String
  label      PhoneLabel @default(MOBILE)
  isPrimary  Boolean    @default(false)
  createdAt  DateTime   @default(now())
  profile    BusinessProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("business_phones")
}

model BusinessSocialLink {
  id        String         @id @default(cuid())
  profileId String
  platform  SocialPlatform
  url       String
  createdAt DateTime       @default(now())
  profile   BusinessProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("business_social_links")
}

model WorkingHours {
  id         String   @id @default(cuid())
  profileId  String
  dayOfWeek  Int
  openTime   String?
  closeTime  String?
  isClosed   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  profile    BusinessProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, dayOfWeek])
  @@map("working_hours")
}

model BusinessMedia {
  id          String      @id @default(cuid())
  profileId   String
  type        MediaType   @default(IMAGE)
  url         String
  caption     String?
  displayOrder Int        @default(0)
  status      MediaStatus @default(PENDING)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  profile     BusinessProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@map("business_media")
}

model BusinessTag {
  id        String   @id @default(cuid())
  profileId String
  tag       String
  createdAt DateTime @default(now())
  profile   BusinessProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, tag])
  @@map("business_tags")
}

model Rating {
  id        String   @id @default(cuid())
  profileId String
  userId    String
  score     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  profile   BusinessProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([profileId, userId])
  @@map("ratings")
}

model Comment {
  id        String        @id @default(cuid())
  profileId String
  userId    String
  body      String        @db.Text
  status    CommentStatus @default(VISIBLE)
  parentId  String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  profile   BusinessProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent    Comment?        @relation("CommentReplies", fields: [parentId], references: [id])
  replies   Comment[]       @relation("CommentReplies")

  @@index([profileId])
  @@map("comments")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  titleAr   String
  bodyAr    String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notifications")
}

model AuditLog {
  id          String      @id @default(cuid())
  actorId     String
  actorEmail  String
  actorRole   Role
  action      AuditAction
  entityType  String
  entityId    String
  newValues   Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime    @default(now())
  actor       User        @relation(fields: [actorId], references: [id])

  @@index([actorId])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

model MediaFile {
  id           String      @id @default(cuid())
  url          String
  thumbnailUrl String?
  mimeType     String
  sizeBytes    Int
  width        Int?
  height       Int?
  altAr        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@map("media_files")
}

model ContactMessage {
  id           String               @id @default(cuid())
  senderId     String?
  senderName   String
  senderEmail  String
  subject      String
  body         String               @db.Text
  status       ContactMessageStatus @default(NEW)
  adminNote    String?              @db.Text
  repliedById  String?
  repliedAt    DateTime?
  replyBody    String?              @db.Text
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  sender       User?                @relation("ContactSender", fields: [senderId], references: [id])
  repliedBy    User?                @relation("ContactReplier", fields: [repliedById], references: [id])

  @@index([status, createdAt(sort: Desc)])
  @@map("contact_messages")
}

// ─────────────────────────────────────────────────────────────────────────────
// PDF SYSTEM MODELS
// ─────────────────────────────────────────────────────────────────────────────

/// Singleton legacy PDF config (one per city or global)
model LegacyPdfConfig {
  id             String               @id @default(cuid())
  cityId         String?              @unique
  titleAr        String               @default("الدليل القديم")
  titleEn        String?
  descriptionAr  String?
  descriptionEn  String?
  buttonLabelAr  String               @default("الدليل القديم")
  buttonLabelEn  String?
  coverImageUrl  String?
  sourceType     PdfLegacySourceType  @default(EXTERNAL_URL)
  fileUrl        String?              // Cloudinary / R2 URL when sourceType = FILE
  externalUrl    String?              // direct external link when sourceType = EXTERNAL_URL
  openMode       PdfLegacyOpenMode    @default(OPEN_IN_NEW_TAB)
  isPublished    Boolean              @default(false)
  publishedAt    DateTime?
  updatedAt      DateTime             @updatedAt
  createdAt      DateTime             @default(now())

  @@map("legacy_pdf_configs")
}

/// A generated directory edition
model PdfEdition {
  id                        String           @id @default(cuid())
  cityId                    String
  cityIdsJson               String           @default("[]")
  slug                      String           @unique
  titleAr                   String
  coverTitleAr              String?
  coverSubtitleAr           String?
  introTextAr               String?          @db.Text
  editorialTextAr           String?          @db.Text
  closingTextAr             String?          @db.Text
  editionNumber             Int              @default(1)
  status                    PdfEditionStatus @default(DRAFT)
  pageSize                  String           @default("A4")
  generationMode            String           @default("ALL_ACTIVE")
  themeJson                 String?          @db.Text
  marginsJson               String?          @db.Text
  layoutJson                String?          @db.Text
  includeAlphabeticalIndex  Boolean          @default(true)
  includeBusinessLogos      Boolean          @default(true)
  includeQrCodes            Boolean          @default(true)
  includeFeaturedBusinesses Boolean          @default(true)
  includeWebsiteProfile     Boolean          @default(false)
  includeDeveloperProfile   Boolean          @default(false)
  showEditionMetadata       Boolean          @default(true)
  publishedAt               DateTime?
  archivedAt                DateTime?
  createdAt                 DateTime         @default(now())
  updatedAt                 DateTime         @updatedAt

  city             City                 @relation(fields: [cityId], references: [id])
  generationJobs   PdfGenerationJob[]
  editionCategories PdfEditionCategory[]
  editionAds       PdfEditionAd[]

  @@index([cityId])
  @@index([status])
  @@map("pdf_editions")
}

/// Async job that generates a PDF edition
model PdfGenerationJob {
  id             String       @id @default(cuid())
  editionId      String
  triggeredById  String?
  status         PdfJobStatus @default(QUEUED)
  startedAt      DateTime?
  finishedAt     DateTime?
  errorMessage   String?
  outputFileUrl  String?
  pagesCount     Int?
  fileSizeBytes  Int?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  edition PdfEdition @relation(fields: [editionId], references: [id], onDelete: Cascade)

  @@index([editionId])
  @@map("pdf_generation_jobs")
}

/// Ad that appears inside a PDF edition
model PdfAd {
  id                       String             @id @default(cuid())
  titleAr                  String
  titleEn                  String?
  imageUrl                 String
  linkUrl                  String?
  placementType            PdfAdPlacementType @default(FULL_PAGE)
  categoryId               String?
  positionAfterCategoryId  String?
  priority                 Int                @default(0)
  isActive                 Boolean            @default(true)
  startsAt                 DateTime?
  endsAt                   DateTime?
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt

  category              Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  positionAfterCategory Category?      @relation("PdfAdPositionAfter", fields: [positionAfterCategoryId], references: [id], onDelete: SetNull)
  editionAds            PdfEditionAd[]

  @@map("pdf_ads")
}

/// M-N join: which ads appear in which editions
model PdfEditionAd {
  id        String   @id @default(cuid())
  editionId String
  adId      String
  createdAt DateTime @default(now())

  edition PdfEdition @relation(fields: [editionId], references: [id], onDelete: Cascade)
  ad      PdfAd      @relation(fields: [adId], references: [id], onDelete: Cascade)

  @@unique([editionId, adId])
  @@map("pdf_edition_ads")
}

/// Which categories are included in a specific edition, with settings
model PdfEditionCategory {
  id               String              @id @default(cuid())
  editionId        String
  categoryId       String
  displayOrder     Int                 @default(0)
  listingTemplate  PdfListingTemplate  @default(STANDARD)
  sortMode         PdfSortMode         @default(FEATURED_FIRST)
  maxListings      Int?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  edition  PdfEdition @relation(fields: [editionId], references: [id], onDelete: Cascade)
  category Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([editionId, categoryId])
  @@map("pdf_edition_categories")
}
