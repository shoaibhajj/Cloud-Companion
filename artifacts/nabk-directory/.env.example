## دليل النبك — environment variables

# Database (required)
DATABASE_URL="postgresql://nabk:changeme@localhost:5432/nabk_directory?schema=public"

# NextAuth (required) — generate with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-32-byte-secret"
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Resend (optional — emails fall back to console.log if missing)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@example.com"

# Google OAuth (optional — Google sign-in is hidden if missing)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Object storage (optional — falls back to placeholder)
DEFAULT_OBJECT_STORAGE_BUCKET_ID=""
PUBLIC_OBJECT_SEARCH_PATHS=""

# Docker compose database (used by docker-compose.yml)
POSTGRES_USER=nabk
POSTGRES_PASSWORD=changeme
POSTGRES_DB=nabk_directory
